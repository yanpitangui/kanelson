@using System.Globalization
@inject NavigationManager Navigation

<select class="k-select-culture" value="@CultureInfo.CurrentCulture.Name" @onchange="OnCultureChange">
    @foreach (var culture in _supportedCultures)
    {
        <option value="@culture.Name">@culture.DisplayName</option>
    }
</select>

@code {
    private readonly CultureInfo[] _supportedCultures = { new("en-US"), new("pt-BR") };

    private void OnCultureChange(ChangeEventArgs e)
    {
        var cultureName = e.Value?.ToString();
        if (cultureName is null || cultureName == CultureInfo.CurrentCulture.Name) return;

        var uri = new Uri(Navigation.Uri).GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        Navigation.NavigateTo(
            $"Culture/Set?culture={Uri.EscapeDataString(cultureName)}&redirectUri={Uri.EscapeDataString(uri)}",
            forceLoad: true);
    }
}
