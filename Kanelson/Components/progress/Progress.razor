@namespace Kanelson.Components.progress
@using System.Globalization

<div class="k-timer">
    <svg class="k-timer__svg" viewBox="0 0 36 36" aria-hidden="true">
        <circle class="k-timer__track" cx="18" cy="18" r="15.9155" />
        <circle class="k-timer__fill" cx="18" cy="18" r="15.9155"
                stroke-dasharray="100 100"
                stroke-dashoffset="@((100 - Percent).ToString("F2", CultureInfo.InvariantCulture))" />
    </svg>
    <span class="k-timer__label">@Format(Percent)</span>
</div>

@code {
    [Parameter] public double Percent { get; set; }
    [Parameter] public Func<double, string> Format { get; set; } = p => $"{(int)p}";
    [Parameter] public string Status { get; set; } = string.Empty;
    [Parameter] public string Type { get; set; } = string.Empty;
    [Parameter] public string TrailColor { get; set; } = string.Empty;
}
