@namespace Kanelson.Components.progress

<div class="k-timer">
    <div class="k-timer__ring"
         style="background: conic-gradient(var(--k-accent) @(Percent)%, var(--k-timer-track) @(Percent)%);">
        <span class="k-timer__value">@Format(Percent)</span>
    </div>
</div>

@code {
    [Parameter] public double Percent { get; set; }
    [Parameter] public Func<double, string> Format { get; set; } = p => $"{(int)p}";
    [Parameter] public string Status { get; set; } = string.Empty;
    [Parameter] public string Type { get; set; } = string.Empty;
    [Parameter] public string TrailColor { get; set; } = string.Empty;
}