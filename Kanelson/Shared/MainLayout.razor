@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true"/>
<MudPopoverProvider />
<MudSnackbarProvider/>

<PageTitle>Kanelson</PageTitle>
<MudLayout>
    <MudAppBar Elevation="0" Style="background-color: #0d0808; border-bottom: 1px solid rgba(255,255,255,0.06);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="DrawerToggle"/>
        <span class="k-logo">
            <span class="k-logo__ka">Ka</span><span class="k-logo__nelson">nelson</span>
        </span>
        <MudSpacer/>
        <LoginDisplay/>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Temporary" Elevation="1" Style="background-color: #0d0808; border-right: 1px solid rgba(255,255,255,0.06);">
        <MudDrawerHeader>
            <span class="k-logo">
                <span class="k-logo__ka">Ka</span><span class="k-logo__nelson">nelson</span>
            </span>
        </MudDrawerHeader>
        <NavMenu/>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-16">
            @Body
            <footer class="k-footer">
                <span class="k-footer__copy">Copyright © @DateTime.Today.Year Kanelson.</span>
                <CultureSelector />
            </footer>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = false;

    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#ff4500",
            AppbarBackground = "#0d0808",
            DrawerBackground = "#0d0808",
            Background = "#100a0a",
            Surface = "rgba(255,255,255,0.04)",
            TextPrimary = "#f1f5f9",
            TextSecondary = "#64748b",
            ActionDefault = "#f1f5f9",
            DrawerText = "#f1f5f9",
            AppbarText = "#f1f5f9",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#ff4500",
            AppbarBackground = "#0d0808",
            DrawerBackground = "#0d0808",
            Background = "#100a0a",
            Surface = "rgba(255,255,255,0.04)",
            TextPrimary = "#f1f5f9",
            TextSecondary = "#64748b",
            ActionDefault = "#f1f5f9",
            DrawerText = "#f1f5f9",
            AppbarText = "#f1f5f9",
        }
    };
}
