@page "/room/{Id}"
@layout Kanelson.Shared.GameLayout

<div class="game-header">
    <span class="game-header__room-id">@Loc["Room"]: @Id</span>
    <ConnectedUsersComponent ConnectedUsers="_connectedUsers"/>
</div>

<div class="game-body">
    @if (_summary is not null)
    {
        @if (_summary.Owner.Id == UserService.CurrentUser)
        {
            <Admin RoomId="@Id" TimerConfiguration="_timerConfig"/>
        }
        else
        {
            <Player RoomId="@Id" TimerConfiguration="_timerConfig"/>
        }
    }
    else
    {
        <div style="color: var(--k-text-muted); text-align: center; padding-top: 40px;">@Loc["Loading"]...</div>
    }
</div>

@code {
}
