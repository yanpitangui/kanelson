@using Kanelson.Domain.Questions

<button class="alt-tile @_tileClass" @onclick="OnClick">
    <span class="alt-tile-letter">@_letter</span>
    <span>@Alternative.Description</span>
</button>

@code {
    private static readonly char[] Letters = ['A', 'B', 'C', 'D'];

    [Parameter] public int Idx { get; set; }
    [Parameter] public Alternative Alternative { get; set; } = null!;
    [Parameter] public EventCallback<Guid> OnClickCallback { get; set; }

    private string _tileClass = string.Empty;
    private char _letter;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _tileClass = AlternativeColor.GetColor(Idx).Code;
        _letter = Letters[Idx % Letters.Length];
    }

    private async Task OnClick() => await OnClickCallback.InvokeAsync(Alternative.Id);
}