@using Kanelson.Domain.Rooms
@inject IStringLocalizer<Shared> Loc

<div class="connected-users">
    @if (RoomUrl is not null)
    {
        <div class="qr-join">
            <span class="qr-join__label">@Loc["ScanToJoin"]</span>
            <QrCodeComponent Url="@RoomUrl" />
        </div>
    }
    <div class="connected-users__header">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
        </svg>
        <span class="connected-users__count">@ConnectedUsers.Count</span>
    </div>
    @if (ConnectedUsers.Count > 0)
    {
        <ul class="connected-users__list">
            @foreach (var user in ConnectedUsers)
            {
                <li class="connected-users__item">
                    <Avatar GithubId="@user.Id" Name="@user.Name"/>
                    <span class="connected-users__name">@user.Name</span>
                    @if (user.Owner)
                    {
                        <span class="connected-users__host-badge">HOST</span>
                    }
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter]
    public HashSet<RoomUser> ConnectedUsers { get; set; } = new();

    [Parameter]
    public string? RoomUrl { get; set; }
}
