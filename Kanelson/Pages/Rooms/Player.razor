@using Kanelson.Components.progress
@using Kanelson.Domain.Rooms.Models
@using Kanelson.Domain.Questions
@inherits BaseRoomPage

@if (CurrentQuestion is not null)
{
    @if (TimerConfiguration.Enabled)
    {
        <Progress Status="ProgressStatus.Active" Type="ProgressType.Circle"
                  TrailColor="#ff4d4f"
                  Percent="@TimerConfiguration.Percentage" Format="TimerConfiguration.Format"/>
    }
    <QuestionComponent AnswerClickCallback="@Answer"
                       OnMultiCorrectSubmit="@AnswerMulti"
                       OnSelectionsChanged="@(ids => OnMultiSelectionsChanged(ids))"
                       Disabled="@(_playerStatus == PlayerStatus.Answered)"
                       PreSelectedAnswers="@_myAnswers"
                       Info="@CurrentQuestion"/>
    @if (_playerStatus == PlayerStatus.Answered)
    {
        <div class="answer-submitted">
            @Loc["AnswerSubmitted"]<span class="waiting-dots"><span>.</span><span>.</span><span>.</span></span>
        </div>
    }
}
else if (Rankings != null)
{
    <UserRanking Ranking="Rankings.Value"/>
}
else if (VoteDistribution.HasValue && VoteDistribution.Value.Length > 0)
{
    <div class="round-summary">
        @if (_roundSummary != null)
        {
            <div class="@ScoreChipClass(_roundSummary.PointsEarned, _roundSummary.Question.Points)">
                +@((int)_roundSummary.PointsEarned) pts
            </div>
        }
        <VoteDistributionComponent Distribution="VoteDistribution.Value"
                                    YourAnswers="@_roundSummary?.Answered" />
    </div>
}
else
{
    <div class="lobby-waiting">
        <div class="lobby-waiting__icon">🎮</div>
        <p class="lobby-waiting__text">
            @Loc["WaitingForHost"]<span class="waiting-dots"><span>.</span><span>.</span><span>.</span></span>
        </p>
    </div>
}
